{
  "version": 2,
  "outputDirectory": "dist",
  "regions": ["gru1"],
  "rewrites": [
    {
      "source": "/api/checkout/create-preference",
      "destination": "/api/checkout/create-preference.ts"
    },
    {
      "source": "/api/webhooks/mercadopago",
      "destination": "/api/webhooks/mercadopago.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}